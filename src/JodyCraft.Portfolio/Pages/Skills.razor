@page "/skills"
@using JodyCraft.Portfolio.Models

<PageTitle>Skills | JodyCraft</PageTitle>

<section class="page-header">
    <div class="container">
        <h1>Skills</h1>
        <p class="lead">技術スタックと経験</p>
    </div>
</section>

<section class="skills-section">
    <div class="container">
        @foreach (var category in skillCategories)
        {
            <div class="skill-category mb-5">
                <h3 class="category-title">@category.Key</h3>
                <div class="row g-3">
                    @foreach (var skill in category.Value)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="skill-card">
                                <div class="skill-header">
                                    <span class="skill-icon">@skill.Icon</span>
                                    <h5 class="skill-name">@skill.Name</h5>
                                </div>
                                <div class="skill-bar-container">
                                    <div class="skill-bar" style="width: @(skill.Proficiency * 20)%"></div>
                                </div>
                                <p class="skill-description">@skill.Description</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>

<section class="learning-section">
    <div class="container">
        <h2 class="section-title">現在学習中</h2>
        <div class="row g-3 justify-content-center">
            <div class="col-auto">
                <span class="learning-badge">WPF / MVVM</span>
            </div>
            <div class="col-auto">
                <span class="learning-badge">Blazor WebAssembly</span>
            </div>
            <div class="col-auto">
                <span class="learning-badge">Azure クラウド</span>
            </div>
            <div class="col-auto">
                <span class="learning-badge">.NET 10</span>
            </div>
        </div>
    </div>
</section>

