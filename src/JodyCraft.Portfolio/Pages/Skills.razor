    {
        ["言語・フレームワーク"] = new()
        {
            new() { Name = "C#", Icon = "C#", Proficiency = 5, Description = "5年の実務経験。業務アプリ開発のメイン言語" },
            new() { Name = ".NET / .NET Framework", Icon = ".N", Proficiency = 4, Description = ".NET 8/9 を使用した最新開発" },
            new() { Name = "WinForms", Icon = "WF", Proficiency = 5, Description = "業務アプリUI開発の中核技術" },
            new() { Name = "Blazor WASM", Icon = "Bz", Proficiency = 2, Description = "Webアプリ開発に挑戦中" },
        },
        ["計測・制御・自動化"] = new()
        {
            new() { Name = "VISA規格 / 計測器通信", Icon = "VI", Proficiency = 4, Description = "HTTP/シリアルによる計測器制御" },
            new() { Name = "カメラ制御 (SDK連携)", Icon = "Cm", Proficiency = 3, Description = "産業用カメラの制御・画像取得" },
            new() { Name = "Excel/CSV自動処理", Icon = "Ex", Proficiency = 4, Description = "成績書自動生成、データ変換" },
            new() { Name = "統計分析・可視化", Icon = "St", Proficiency = 4, Description = "計測データの傾向分析・グラフ化" },
        },
        ["開発ツール・プラクティス"] = new()
