@page "/contact"

<PageTitle>Contact | JodyCraft</PageTitle>

<section class="page-header">
    <div class="container">
        <h1>Contact</h1>
        <p class="lead">お問い合わせ・ご相談</p>
    </div>
</section>

<section class="contact-section">
    <div class="container">
        <div class="row g-5">
            <div class="col-md-7">
                <h2>お問い合わせフォーム</h2>
                <p class="contact-description">技術相談、開発依頼、講演依頼など、お気軽にご連絡ください。</p>

                <form action="https://formspree.io/f/xojnbzwn" method="POST" class="contact-form">
                    <div class="mb-3">
                        <label for="name" class="form-label">お名前 *</label>
                        <input type="text" class="form-control" id="name" name="name" required />
                    </div>

                    <div class="mb-3">
                        <label for="company" class="form-label">会社名</label>
                        <input type="text" class="form-control" id="company" name="company" />
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">メールアドレス *</label>
                        <input type="email" class="form-control" id="email" name="email" required />
                    </div>

                    <div class="mb-3">
                        <label for="subject" class="form-label">ご関心のあるサービス</label>
                        <select class="form-select" id="subject" name="subject">
                            <option value="まずは相談したい">まずは相談したい</option>
                            <option value="業務改善診断">業務改善診断</option>
                            <option value="月額アドバイザー">月額アドバイザー</option>
                            <option value="技術相談">技術相談</option>
                            <option value="開発依頼">開発依頼</option>
                            <option value="その他">その他</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="message" class="form-label">メッセージ *</label>
                        <textarea class="form-control" id="message" name="message" rows="5" required placeholder="現在のお困りごとや、ご質問内容をお書きください"></textarea>
                    </div>

                    <div class="mb-3">
                        <label for="preferred-contact" class="form-label">ご希望の連絡方法</label>
                        <select class="form-select" id="preferred-contact" name="preferred-contact">
                            <option value="メール">メール</option>
                            <option value="オンラインMTG（平日18時以降）">オンラインMTG（平日18時以降）</option>
                            <option value="オンラインMTG（土曜日）">オンラインMTG（土曜日）</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-accent btn-lg">送信する</button>
                </form>

                <p class="contact-note mt-3">
                    ※ フォームは <a href="https://formspree.io" target="_blank">Formspree</a> を使用しています。<br />
                    ※ 通常2営業日以内にご返信いたします。
                </p>
            </div>

            <div class="col-md-5">
                <h2>SNS・リンク</h2>
                <div class="social-links">
                    <a href="https://github.com/joji804" target="_blank" class="social-link-card">
                        <span class="social-icon"><svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.1.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.58 9.58 0 0 1 12 6.8c.85 0 1.7.11 2.5.34 1.9-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.6 1.03 2.69 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85v2.74c0 .27.16.59.67.5A10.02 10.02 0 0 0 22 12c0-5.523-4.477-10-10-10Z"/></svg></span>
                        <div>
                            <strong>GitHub</strong>
                            <p class="mb-0 small text-muted">ソースコード・OSS活動</p>
                        </div>
                    </a>
                    <a href="https://zenn.dev/jodycraft" target="_blank" class="social-link-card">
                        <span class="social-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24"><path d="M12 20h9M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                        <div>
                            <strong>Zenn</strong>
                            <p class="mb-0 small text-muted">技術記事・有料Books</p>
                        </div>
                    </a>
                    <a href="https://instagram.com/jodycraft_dev" target="_blank" class="social-link-card">
                        <span class="social-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37Z"/><path d="M17.5 6.5h.01" stroke-linecap="round"/></svg></span>
                        <div>
                            <strong>Instagram</strong>
                            <p class="mb-0 small text-muted">C#ティップス・Reels</p>
                        </div>
                    </a>
                    <a href="https://x.com/jodycraft_dev" target="_blank" class="social-link-card">
                        <span class="social-icon"><svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></span>
                        <div>
                            <strong>X (Twitter)</strong>
                            <p class="mb-0 small text-muted">技術発信・コミュニティ</p>
                        </div>
                    </a>
                </div>

                <div class="mt-5">
                    <h3>こんな相談ができます</h3>
                    <ul class="consult-list">
                        <li>C#/.NET での業務アプリ開発について</li>
                        <li>製造業の試験自動化・DX化の進め方</li>
                        <li>GitHub Copilot の導入・活用方法</li>
                        <li>WinForms/WPF アプリの設計レビュー</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
