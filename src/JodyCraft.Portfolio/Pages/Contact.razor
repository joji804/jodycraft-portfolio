@page "/contact"

<PageTitle>Contact | JodyCraft</PageTitle>

<section class="page-header">
    <div class="container">
        <h1>Contact</h1>
        <p class="lead">お問い合わせ・ご相談</p>
    </div>
</section>

<section class="contact-section">
    <div class="container">
        <div class="row g-5">
            <div class="col-md-7">
                <h2>お問い合わせフォーム</h2>
                <p class="text-muted mb-4">技術相談、開発依頼、講演依頼など、お気軽にご連絡ください。</p>

                <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="contact-form">
                    <div class="mb-3">
                        <label for="name" class="form-label">お名前 *</label>
                        <input type="text" class="form-control" id="name" name="name" required />
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">メールアドレス *</label>
                        <input type="email" class="form-control" id="email" name="email" required />
                    </div>

                    <div class="mb-3">
                        <label for="subject" class="form-label">件名</label>
                        <select class="form-select" id="subject" name="subject">
                            <option value="技術相談">技術相談</option>
                            <option value="開発依頼">開発依頼</option>
                            <option value="講演依頼">講演依頼</option>
                            <option value="コンサルティング">コンサルティング</option>
                            <option value="その他">その他</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="message" class="form-label">メッセージ *</label>
                        <textarea class="form-control" id="message" name="message" rows="5" required></textarea>
                    </div>

                    <button type="submit" class="btn btn-accent btn-lg">送信する</button>
                </form>

                <p class="text-muted small mt-3">
                    ※ フォームは <a href="https://formspree.io" target="_blank">Formspree</a> を使用しています。<br />
                    ※ 通常2営業日以内にご返信いたします。
                </p>
            </div>

            <div class="col-md-5">
                <h2>SNS・リンク</h2>
                <div class="social-links">
                    <a href="https://github.com/jodycraft" target="_blank" class="social-link-card">
                        <span class="social-icon">🔀</span>
                        <div>
                            <strong>GitHub</strong>
                            <p class="mb-0 small text-muted">ソースコード・OSS活動</p>
                        </div>
                    </a>
                    <a href="https://zenn.dev/jodycraft" target="_blank" class="social-link-card">
                        <span class="social-icon">📝</span>
                        <div>
                            <strong>Zenn</strong>
                            <p class="mb-0 small text-muted">技術記事・有料Books</p>
                        </div>
                    </a>
                    <a href="https://instagram.com/jodycraft" target="_blank" class="social-link-card">
                        <span class="social-icon">📸</span>
                        <div>
                            <strong>Instagram</strong>
                            <p class="mb-0 small text-muted">C#ティップス・Reels</p>
                        </div>
                    </a>
                    <a href="https://x.com/jodycraft" target="_blank" class="social-link-card">
                        <span class="social-icon">💬</span>
                        <div>
                            <strong>X (Twitter)</strong>
                            <p class="mb-0 small text-muted">技術発信・コミュニティ</p>
                        </div>
                    </a>
                </div>

                <div class="mt-5">
                    <h3>対応可能な相談内容</h3>
                    <ul class="consult-list">
                        <li>C#/.NET による業務アプリ開発相談</li>
                        <li>製造業の試験自動化・DX化支援</li>
                        <li>GitHub Copilot 導入コンサルティング</li>
                        <li>WinForms/WPF アプリの設計レビュー</li>
                        <li>勉強会・研修での登壇</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
